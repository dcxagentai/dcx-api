# CONTEXT:
# This file is the single local reference block for the DCX API environment variables used by the
# current backend, including transactional email, newsletter delivery, tracked links, and Resend
# webhooks. Use the same variable names locally in `.env` and on Render in the service
# environment-variable UI.
#
# Two supported modes:
# 1. Local or hosted testing with the real DCX sender and optional local-only recipient override
# 2. Real production mode with the same verified sender and live user delivery

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Preferred:
DB_URL=postgresql://user:password@host:5432/database

# Or discrete fields instead of DB_URL:
# DB_NAME=stephen_dcx
# DB_USER=postgres
# DB_PASSWORD=replace_me
# DB_HOST=localhost
# DB_PORT=5432
# DB_SSLMODE=require

# -----------------------------------------------------------------------------
# Public signup security core
# -----------------------------------------------------------------------------
# Required for signup OTP and signup-flow-token HMAC. Must be a long random secret.
DCX_SIGNUP_OTP_SECRET=replace_me_with_a_long_random_secret

# Exact frontend origins allowed to call the public signup routes.
# Comma-separated if more than one.
DCX_PUBLIC_ALLOWED_ORIGINS=http://localhost:4321

# Set true only when the deployment is behind a trusted proxy and the app should honor
# X-Forwarded-For / X-Real-IP for rate limiting.
DCX_TRUST_PROXY_HEADERS=false

# -----------------------------------------------------------------------------
# Resend delivery core
# -----------------------------------------------------------------------------
# All values below are required for their corresponding flows. The backend now fails loudly if any
# required sender value is missing.
RESEND_API_KEY=replace_me
RESEND_FROM_NAME=The DCX Team

# Transactional/account mail such as signup OTPs and confirmations.
RESEND_FROM_EMAIL_TRANSACTIONAL=team@mail.dcxagent.ai

# Message-thread style mail used for inbound/outbound user messaging flows.
RESEND_FROM_EMAIL_MESSAGES=chat@mail.dcxagent.ai

# Resend webhook signing secret from the Resend dashboard.
# Required if you want the backend to verify delivery / bounce / complaint webhooks.
RESEND_WEBHOOK_SECRET=replace_me

# Inbound message receiving:
# - configure a custom receiving address such as chat@mail.dcxagent.ai in Resend
# - point its `email.received` webhook at https://api.dcxagent.ai/public/webhooks/resend in live
#   or at {DCX_API_BASE_URL}/public/webhooks/resend in local/dev
# - the backend then fetches the body from Resend's receiving API using RESEND_API_KEY
# - route by the `to` address later if you add more inboxes

# Base API URL used when the backend needs to generate absolute public API links for outbound email
# tracking or similar cross-surface redirects. This should be a real reachable hostname when email
# links or webhooks matter.
#
# Examples:
# DCX_API_BASE_URL=https://api.dcxagent.ai
# DCX_API_BASE_URL=https://your-cloudflare-tunnel-host.example
DCX_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Local or hosted testing
# -----------------------------------------------------------------------------
# Leave the override values unset if you want real test emails to go to the actual intended
# recipients. Set them only when you explicitly want all outbound mail forced to one inbox during
# local or development testing.
#
# IMPORTANT:
# - Keep override usage local-only or development-only.
# - The backend blocks override usage outside local/development unless explicitly enabled.
DCX_ENVIRONMENT=development
RESEND_TEST_RECIPIENT=
RESEND_ALLOW_TEST_RECIPIENT_OVERRIDE=false

# Example local admin/app origins:
# DCX_PUBLIC_ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173
#
# Example hosted-test origin:
# DCX_PUBLIC_ALLOWED_ORIGINS=https://your-public-render-or-pages-host.example

# If you want Resend to post webhooks into a local backend, point the Resend webhook URL at:
#   {DCX_API_BASE_URL}/public/webhooks/resend
# A Cloudflare tunnel is a good fit for this local test path.

# -----------------------------------------------------------------------------
# Real production mode
# -----------------------------------------------------------------------------
# For the real production switch:
# - set DCX_ENVIRONMENT=production
# - leave RESEND_TEST_RECIPIENT unset
# - leave RESEND_ALLOW_TEST_RECIPIENT_OVERRIDE=false
# - keep both RESEND_FROM_EMAIL_TRANSACTIONAL and RESEND_FROM_EMAIL_MESSAGES on verified DCX senders
# - register the Resend webhook URL as https://api.dcxagent.ai/public/webhooks/resend
#
# Example:
# DCX_ENVIRONMENT=production
# DCX_PUBLIC_ALLOWED_ORIGINS=https://www.your-real-public-domain.com
# DCX_API_BASE_URL=https://api.dcxagent.ai

# -----------------------------------------------------------------------------
# Message derivation LLM
# -----------------------------------------------------------------------------
# Optional for the first-pass message inbox. If omitted, the backend stores raw text directly and
# marks the derivation as fallback_no_model.
OPENAI_API_KEY=
DCX_OPENAI_MESSAGE_DERIVATION_MODEL=gpt-5.2

# -----------------------------------------------------------------------------
# Meta WhatsApp inbound + acknowledgement messaging
# -----------------------------------------------------------------------------
# Webhook verify token used during the Meta GET challenge handshake.
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_me

# Meta app secret used to verify X-Hub-Signature-256 on inbound webhook POST requests.
META_APP_SECRET=replace_me

# Existing Cloud API send credentials, also reused for simple inbound acknowledgements.
META_API_VERSION=v23.0
META_PHONE_NUMBER_ID=replace_me
META_WHATSAPP_TOKEN=replace_me

# Register the Meta webhook URL as:
#   {DCX_API_BASE_URL}/public/webhooks/meta-whatsapp

# -----------------------------------------------------------------------------
# Cloudflare R2 hello-world media plumbing
# -----------------------------------------------------------------------------
# S3-compatible R2 endpoint. If omitted, the backend derives it from DCX_R2_ACCOUNT_ID.
# DCX_R2_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
DCX_R2_ACCOUNT_ID=replace_me
DCX_R2_ACCESS_KEY_ID=replace_me
DCX_R2_SECRET_ACCESS_KEY=replace_me

# Concrete bucket names for the minimal hello-world route under /files/hello-world.
DCX_R2_APP_BUCKET_NAME=prompteo-dev-app-files
DCX_R2_PUBLIC_BUCKET_NAME=prompteo-dev-public-files
