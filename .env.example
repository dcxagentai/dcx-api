# CONTEXT:
# This file is the single local reference block for the DCX API environment variables used by the
# public email-signup / OTP flow. Use the same variable names locally in `.env` and on Render in
# the service environment-variable UI.
#
# Two supported modes:
# 1. Hosted test mode without a verified client domain yet
# 2. Real production mode with verified sender domain and real-user delivery

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Preferred:
PROMPTEO_DB_URL=postgresql://user:password@host:5432/database

# Or discrete fields instead of PROMPTEO_DB_URL:
# PROMPTEO_DB_NAME=stephen_dcx
# PROMPTEO_DB_USER=postgres
# PROMPTEO_DB_PASSWORD=replace_me
# PROMPTEO_DB_HOST=localhost
# PROMPTEO_DB_PORT=5432
# PROMPTEO_DB_SSLMODE=require

# -----------------------------------------------------------------------------
# Public email-signup security core
# -----------------------------------------------------------------------------
# Required for OTP and signup-flow-token HMAC. Must be a long random secret.
DCX_EMAIL_SIGNUP_OTP_SECRET=replace_me_with_a_long_random_secret

# Exact frontend origins allowed to call the public signup routes.
# Comma-separated if more than one.
DCX_PUBLIC_ALLOWED_ORIGINS=http://localhost:4321

# Set true only when the deployment is behind a trusted proxy and the app should honor
# X-Forwarded-For / X-Real-IP for rate limiting.
DCX_TRUST_PROXY_HEADERS=false

# -----------------------------------------------------------------------------
# Resend delivery core
# -----------------------------------------------------------------------------
# All three values below are required. The backend now fails loudly if any are missing.
RESEND_API_KEY=replace_me
DCX_EMAIL_SIGNUP_RESEND_FROM_NAME=DCX

# Use a real, deliberate sender value here even in development.
# For hosted test mode this can still be a Resend-safe sender you intentionally configured.
# For real production it must be an address on a verified Resend domain.
DCX_EMAIL_SIGNUP_RESEND_FROM_EMAIL=onboarding@resend.dev

# -----------------------------------------------------------------------------
# Hosted test mode on Render or locally
# -----------------------------------------------------------------------------
# Use this until the client has a verified sending domain and we still want OTP mail routed to
# Resend's safe test inbox.
#
# IMPORTANT:
# - This is NOT the final real-production sending setup.
# - Leave these unset once we switch to real-user delivery.
DCX_ENVIRONMENT=development
DCX_EMAIL_SIGNUP_RESEND_TEST_RECIPIENT=delivered@resend.dev
DCX_EMAIL_SIGNUP_ALLOW_TEST_RECIPIENT_OVERRIDE=true

# Example hosted-test origin:
# DCX_PUBLIC_ALLOWED_ORIGINS=https://your-public-render-or-pages-host.example

# -----------------------------------------------------------------------------
# Real production mode
# -----------------------------------------------------------------------------
# For the real production switch:
# - set DCX_ENVIRONMENT=production
# - remove DCX_EMAIL_SIGNUP_RESEND_TEST_RECIPIENT
# - remove DCX_EMAIL_SIGNUP_ALLOW_TEST_RECIPIENT_OVERRIDE
# - set DCX_EMAIL_SIGNUP_RESEND_FROM_EMAIL to a verified domain sender
#
# Example:
# DCX_ENVIRONMENT=production
# DCX_PUBLIC_ALLOWED_ORIGINS=https://www.your-real-public-domain.com
# DCX_EMAIL_SIGNUP_RESEND_FROM_EMAIL=noreply@your-real-public-domain.com

# -----------------------------------------------------------------------------
# Cloudflare R2 hello-world media plumbing
# -----------------------------------------------------------------------------
# S3-compatible R2 endpoint. If omitted, the backend derives it from DCX_R2_ACCOUNT_ID.
# DCX_R2_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
DCX_R2_ACCOUNT_ID=replace_me
DCX_R2_ACCESS_KEY_ID=replace_me
DCX_R2_SECRET_ACCESS_KEY=replace_me

# Concrete bucket names for the minimal hello-world route under /files/hello-world.
DCX_R2_APP_BUCKET_NAME=prompteo-dev-app-files
DCX_R2_PUBLIC_BUCKET_NAME=prompteo-dev-public-files
